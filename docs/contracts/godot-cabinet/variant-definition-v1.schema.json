{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lucky5.local/contracts/godot-cabinet/variant-definition-v1.schema.json",
  "title": "Lucky5 VariantDefinition v1",
  "description": "Governed variant metadata for Lucky5 cabinet clients. This schema describes release gates and presentation metadata; it is not a game-rule implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "variant_id",
    "display_name",
    "family",
    "status",
    "ruleset_version",
    "paytable",
    "paytable_hash",
    "rtp_gate",
    "double_up_profile",
    "jackpot_profile",
    "machine_policy",
    "cabinet_skin",
    "presentation_profile",
    "governance",
    "production_activation",
    "compatibility"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "variant.v1"
    },
    "variant_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "display_name": { "type": "string" },
    "family": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "simulation_pending", "approved", "active", "retired"]
    },
    "ruleset_version": { "type": "string" },
    "paytable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "RoyalFlush",
        "StraightFlush",
        "FourOfAKind",
        "FullHouse",
        "Flush",
        "Straight",
        "ThreeOfAKind",
        "TwoPair"
      ],
      "properties": {
        "RoyalFlush": { "type": "number", "exclusiveMinimum": 0 },
        "StraightFlush": { "type": "number", "exclusiveMinimum": 0 },
        "FourOfAKind": { "type": "number", "exclusiveMinimum": 0 },
        "FullHouse": { "type": "number", "exclusiveMinimum": 0 },
        "Flush": { "type": "number", "exclusiveMinimum": 0 },
        "Straight": { "type": "number", "exclusiveMinimum": 0 },
        "ThreeOfAKind": { "type": "number", "exclusiveMinimum": 0 },
        "TwoPair": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "paytable_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "rtp_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "simulation_required",
        "simulation_status",
        "minimum_rounds",
        "target_rtp",
        "tolerance_bps",
        "report_uri",
        "approved_for_production"
      ],
      "properties": {
        "simulation_required": { "type": "boolean" },
        "simulation_status": {
          "type": "string",
          "enum": ["not_run", "running", "failed", "passed"]
        },
        "minimum_rounds": { "type": "integer", "minimum": 1 },
        "target_rtp": {
          "oneOf": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "type": "null" }
          ]
        },
        "tolerance_bps": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "report_uri": { "type": "string" },
        "approved_for_production": { "type": "boolean" }
      }
    },
    "double_up_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "choices",
        "switch_enabled",
        "lucky_card",
        "take_half_enabled",
        "take_score_enabled"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "choices": {
          "type": "array",
          "items": { "type": "string", "enum": ["big", "small"] },
          "uniqueItems": true
        },
        "switch_enabled": { "type": "boolean" },
        "lucky_card": {
          "type": "string",
          "pattern": "^(?:[2-9]|10|J|Q|K|A)[HDCS]$"
        },
        "take_half_enabled": { "type": "boolean" },
        "take_score_enabled": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "jackpot_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meters", "counter_labels"],
      "properties": {
        "meters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "display_name"],
            "properties": {
              "id": { "type": "string" },
              "display_name": { "type": "string" }
            }
          }
        },
        "counter_labels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "machine_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_bet_source",
        "max_bet_source",
        "cash_in_unit_source",
        "cash_out_threshold_source",
        "authoritative_balance_owner"
      ],
      "properties": {
        "min_bet_source": { "type": "string" },
        "max_bet_source": { "type": "string" },
        "cash_in_unit_source": { "type": "string" },
        "cash_out_threshold_source": { "type": "string" },
        "authoritative_balance_owner": {
          "type": "string",
          "enum": ["backend"]
        }
      }
    },
    "cabinet_skin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skin_id", "asset_root", "button_assets", "palette", "identity_notes"],
      "properties": {
        "skin_id": { "type": "string" },
        "asset_root": { "type": "string" },
        "button_assets": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "palette": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "identity_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "presentation_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "layout", "timings_ms", "ux_rules"],
      "properties": {
        "profile_id": { "type": "string" },
        "layout": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height", "orientation"],
          "properties": {
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 },
            "orientation": {
              "type": "string",
              "enum": ["portrait", "landscape"]
            }
          }
        },
        "timings_ms": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "integer", "minimum": 0 },
              {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": { "type": "integer", "minimum": 0 }
              }
            ]
          }
        },
        "ux_rules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "approved_by",
        "approved_at_utc",
        "change_ticket",
        "simulation_report_id",
        "notes"
      ],
      "properties": {
        "owner": { "type": "string" },
        "approved_by": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "approved_at_utc": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "change_ticket": { "type": "string" },
        "simulation_report_id": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "production_activation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "required_gates"],
      "properties": {
        "enabled": { "type": "boolean" },
        "required_gates": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "paytable_hash_match",
              "rtp_simulation_passed",
              "governance_approved",
              "skin_assets_verified",
              "backend_schema_compatible",
              "godot_schema_compatible"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_backend_contract", "minimum_godot_contract"],
      "properties": {
        "minimum_backend_contract": { "type": "string" },
        "minimum_godot_contract": { "type": "string" }
      }
    }
  }
}
