# Lucky5 web cabinet — local dev environment overrides.
# Copy to `.env.local` and adjust as needed. Both vars are optional.

# Origin of the .NET API. Used at build time by next.config.mjs for proxy
# rewrites (`/api/*` and `/assets/*`). Defaults to http://localhost:5000.
LUCKY5_API_ORIGIN=http://localhost:5000

# Browser-side prefix for fetch() calls in lib/api.ts. Leave empty in dev so
# requests are same-origin and pass through the Next rewrites above. In a
# split deployment (cabinet served from a CDN, API on a different host),
# set this to the API origin and disable the rewrites.
NEXT_PUBLIC_API_BASE=
